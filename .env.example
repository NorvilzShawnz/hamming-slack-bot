# ── Slack ──────────────────────────────────────────
# From https://api.slack.com/apps → Your App → OAuth & Permissions
SLACK_BOT_TOKEN=[]

# From https://api.slack.com/apps → Your App → Basic Information → Signing Secret
SLACK_SIGNING_SECRET=[]

# Only needed for Socket Mode (recommended for dev / firewalled environments)
# From https://api.slack.com/apps → Your App → Basic Information → App-Level Tokens
SLACK_APP_TOKEN=[]

# ── Hamming ─────────────────────────────────────────
# From https://app.hamming.ai/settings → Create new secret key
HAMMING_API_KEY=[]

# ── Server ──────────────────────────────────────────
PORT=3000
